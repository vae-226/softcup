@import "../guide/guide.wxss";

.route-page-content {
  padding-bottom: 72rpx;
}

.route-overview {
  margin-top: 48rpx;
}

.featured-route {
  border-radius: 30rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.76);
  border: 1rpx solid rgba(197, 165, 90, 0.2);
  box-shadow: 0 14rpx 32rpx rgba(42, 33, 22, 0.1);
}

.featured-image {
  width: 100%;
  height: 310rpx;
  display: block;
}

.featured-body {
  padding: 28rpx;
}

.route-focus {
  display: block;
  margin-top: 18rpx;
  color: #555;
  font-size: 23rpx;
  line-height: 1.65;
}

.route-list-section {
  margin-top: 32rpx;
  margin-bottom: 72rpx;
  display: grid;
  gap: 24rpx;
}

.route-card-full {
  width: 100%;
  flex: none;
}
