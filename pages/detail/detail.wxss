@import "../guide/guide.wxss";

.detail-content {
  padding-bottom: 80rpx;
}

.detail-hero {
  margin-top: 40rpx;
}

.detail-image {
  width: 100%;
  height: 360rpx;
  border-radius: 28rpx;
  display: block;
  margin-bottom: 28rpx;
}

.detail-text {
  display: block;
  margin-top: 22rpx;
  color: #4b453d;
  font-size: 27rpx;
  line-height: 1.75;
}

.knowledge-row {
  padding: 24rpx;
  border-radius: 22rpx;
  background: rgba(255,255,255,.72);
  border: 1rpx solid rgba(197,165,90,.18);
  margin-top: 16rpx;
}

.knowledge-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
}

.knowledge-meta {
  display: block;
  margin-top: 8rpx;
  color: #777;
  font-size: 22rpx;
}
