.admin-page {
  min-height: 100vh;
  background: #faf9f6;
  color: #1b1d0e;
  position: relative;
}

.admin-scroll {
  height: 100vh;
  box-sizing: border-box;
}

.topbar {
  position: sticky;
  top: 0;
  z-index: 10;
  padding: 28rpx 32rpx;
  background: rgba(250, 249, 246, 0.94);
  border-bottom: 1rpx solid rgba(95, 94, 94, 0.1);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.brand {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.avatar,
.avatar-preview {
  border-radius: 50%;
  background: linear-gradient(145deg, #b22222, #cca72f);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: serif;
  font-weight: 700;
}

.avatar {
  width: 64rpx;
  height: 64rpx;
  font-size: 34rpx;
}

.title {
  font-size: 34rpx;
  font-weight: 700;
  color: #8f000d;
  line-height: 1.25;
}

.subtitle {
  margin-top: 4rpx;
  font-size: 21rpx;
  color: #5f5e5e;
}

.notice {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  border: 1rpx solid rgba(95, 94, 94, 0.16);
  color: #5f5e5e;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.content {
  padding: 36rpx 32rpx 260rpx;
  box-sizing: border-box;
}

.section-title,
.panel-title,
.panel-head,
.metric-delta,
.trend-head,
.feedback-top,
.knowledge-actions {
  display: flex;
  align-items: center;
}

.section-title {
  gap: 12rpx;
  margin-bottom: 24rpx;
  font-size: 34rpx;
  font-weight: 700;
}

.title-mark,
.panel-icon {
  color: #8f000d;
}

.metric-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.metric-card,
.panel,
.feedback-card {
  background: #faf9f6;
  border: 1rpx solid rgba(95, 94, 94, 0.12);
  border-radius: 16rpx;
}

.metric-card {
  padding: 24rpx;
  min-height: 150rpx;
  border-left: 4rpx solid rgba(143, 0, 13, 0.7);
  box-sizing: border-box;
}

.metric-wide {
  grid-column: 1 / -1;
}

.metric-label {
  display: block;
  color: #5f5e5e;
  font-size: 24rpx;
}

.metric-value {
  display: block;
  margin-top: 8rpx;
  color: #1a1a1a;
  font-size: 44rpx;
  font-weight: 700;
}

.metric-delta {
  margin-top: 12rpx;
  color: #8f000d;
  font-size: 22rpx;
}

.metric-track,
.trend-track {
  margin-top: 18rpx;
  height: 8rpx;
  background: #e4e4cc;
  border-radius: 999rpx;
  overflow: hidden;
}

.metric-fill,
.trend-fill {
  height: 100%;
  background: #8f000d;
  border-radius: inherit;
}

.bento-grid,
.panel {
  margin-top: 42rpx;
}

.panel {
  padding: 30rpx;
}

.panel-title {
  gap: 12rpx;
  margin-bottom: 26rpx;
  font-size: 31rpx;
  font-weight: 700;
}

.panel-head {
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
  margin-bottom: 26rpx;
}

.panel-head .panel-title {
  flex: 1;
  min-width: 260rpx;
  margin-bottom: 0;
}

.avatar-panel {
  text-align: center;
}

.avatar-preview {
  width: 176rpx;
  height: 176rpx;
  margin: 0 auto 24rpx;
  font-size: 82rpx;
  border: 4rpx solid rgba(143, 0, 13, 0.16);
}

.form-row {
  padding: 18rpx 0;
  border-bottom: 1rpx solid rgba(95, 94, 94, 0.18);
  text-align: left;
}

.form-label {
  display: block;
  color: #5f5e5e;
  font-size: 21rpx;
}

.form-value {
  display: block;
  margin-top: 8rpx;
  font-size: 28rpx;
  color: #1a1a1a;
}

.form-input {
  width: 100%;
  height: 58rpx;
  margin-top: 8rpx;
  color: #1a1a1a;
  font-size: 28rpx;
  font-weight: 700;
  background: transparent;
}

.primary-btn,
.upload-btn,
.icon-btn,
.outline-btn {
  border-radius: 8rpx;
  font-size: 24rpx;
  margin: 0;
  box-sizing: border-box;
}

.primary-btn::after,
.upload-btn::after,
.icon-btn::after,
.outline-btn::after {
  border: 0;
}

.primary-btn {
  width: 320rpx;
  height: 84rpx;
  margin: 28rpx auto 0;
  background: #8f000d;
  color: #faf9f6;
  line-height: 84rpx;
}

.subhead {
  margin: 12rpx 0 18rpx;
  color: #5f5e5e;
  font-size: 26rpx;
}

.trend-row {
  margin-bottom: 22rpx;
}

.trend-head {
  justify-content: space-between;
  font-size: 23rpx;
}

.gold {
  color: #c5a028;
}

.gray {
  color: #666;
}

.red {
  color: #8f000d;
}

.trend-fill.gold {
  background: #c5a028;
}

.trend-fill.gray {
  background: #666;
}

.trend-fill.red {
  background: #8f000d;
}

.focus-head {
  margin-top: 32rpx;
}

.tag-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.focus-tag {
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(143, 0, 13, 0.12);
  background: linear-gradient(135deg, #faf9f6, #efefd7);
  color: #1a1a1a;
  font-size: 22rpx;
}

.suggestion {
  margin-top: 26rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(115, 92, 0, 0.2);
  background: #fbfbe2;
  color: rgba(27, 29, 14, 0.82);
  line-height: 1.7;
  font-size: 24rpx;
}

.suggestion-title {
  color: #735c00;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.upload-btn {
  flex: none;
  width: 260rpx;
  height: 64rpx;
  padding: 0;
  background: #8f000d;
  color: #faf9f6;
  line-height: 64rpx;
}

.knowledge-row {
  padding: 24rpx 0;
  border-bottom: 1rpx solid rgba(26, 26, 26, 0.1);
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.knowledge-main {
  width: 100%;
  min-width: 0;
}

.knowledge-title {
  display: block;
  font-size: 27rpx;
  font-weight: 700;
  line-height: 1.45;
  white-space: normal;
}

.knowledge-tags {
  margin-top: 10rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.knowledge-tags text {
  padding: 5rpx 12rpx;
  border-radius: 8rpx;
  background: #efefd7;
  color: #5f5e5e;
  font-size: 19rpx;
}

.knowledge-actions {
  gap: 12rpx;
  display: grid;
  grid-template-columns: auto minmax(120rpx, 1fr) minmax(120rpx, 1fr);
  width: 100%;
  align-items: center;
}

.status {
  border-radius: 8rpx;
  padding: 8rpx 12rpx;
  font-size: 20rpx;
  line-height: 1.3;
  white-space: nowrap;
}

.status.enabled {
  color: #735c00;
  background: rgba(197, 160, 40, 0.12);
}

.status.pending {
  color: #666;
  background: rgba(95, 94, 94, 0.12);
}

.status.disabled {
  color: #8f000d;
  background: rgba(143, 0, 13, 0.1);
}

.icon-btn {
  width: 100%;
  height: 46rpx;
  border-radius: 8rpx;
  color: #5f5e5e;
  border: 1rpx solid rgba(95, 94, 94, 0.16);
  font-size: 20rpx;
  line-height: 46rpx;
  padding: 0;
  background: #faf9f6;
}

.feedback-card {
  padding: 24rpx;
  margin-top: 20rpx;
}

.feedback-top {
  justify-content: space-between;
}

.stars {
  color: #c8c6c5;
  font-size: 24rpx;
}

.stars .lit {
  color: #c5a028;
}

.feedback-time {
  color: #5f5e5e;
  font-size: 20rpx;
}

.sentiment-tag {
  display: inline-block;
  margin-top: 12rpx;
  padding: 5rpx 12rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
}

.sentiment-tag.Positive {
  color: #735c00;
  background: rgba(197, 160, 40, 0.14);
}

.sentiment-tag.Neutral {
  color: #5f5e5e;
  background: rgba(95, 94, 94, 0.12);
}

.feedback-content {
  display: block;
  margin-top: 16rpx;
  color: #1a1a1a;
  font-size: 26rpx;
  line-height: 1.7;
}

.outline-btn {
  margin-top: 18rpx;
  width: 100%;
  height: 64rpx;
  padding: 0 20rpx;
  border: 1rpx solid #8f000d;
  color: #8f000d;
  background: transparent;
  line-height: 64rpx;
}

.outline-btn.handled {
  border-color: rgba(95, 94, 94, 0.22);
  color: #5f5e5e;
  background: rgba(95, 94, 94, 0.08);
}
