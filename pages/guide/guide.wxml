<view class="page-shell">
  <scroll-view class="content" scroll-y enhanced show-scrollbar="{{false}}">
    <view class="status-bar">
      <text class="time">09:41</text>
      <view class="status-right">
        <text class="location">{{scenic.name}}</text>
        <text>信号</text>
        <text>WiFi</text>
        <text>电量</text>
      </view>
    </view>

    <view class="hero">
      <view class="ink-bg"></view>
      <view class="avatar-wrap {{currentMood}}">
        <view class="avatar-face">
          <text class="avatar-mark">灵</text>
          <text class="avatar-sub">AI</text>
        </view>
        <view class="listening">正在聆听...</view>
      </view>

      <view class="dialogue-card">
        <view class="bubble-tip"></view>
        <text class="dialogue-text">{{dialogue}}</text>
        <view class="wave-row">
          <view class="wave wave-1"></view>
          <view class="wave wave-2"></view>
          <view class="wave wave-3"></view>
          <view class="wave wave-4"></view>
          <view class="wave wave-5"></view>
        </view>
      </view>
    </view>

    <view class="control-row">
      <button class="side-action" bindtap="useQuickQuestion" data-question="灵山梵宫有什么特色？">文</button>
      <button class="voice-action" bindtap="askQuestion">麦</button>
      <button class="side-action" bindtap="useQuickQuestion" data-question="九龙灌浴适合孩子看吗？">拍</button>
    </view>

    <view class="question-box">
      <input class="question-input" placeholder="问问灵灵：灵山大佛有什么特色？" value="{{question}}" bindinput="onQuestionInput" confirm-type="send" bindconfirm="askQuestion" />
      <button class="send-btn" bindtap="askQuestion">发送</button>
    </view>

    <view class="section">
      <view class="section-head">
        <view class="section-title">推荐路线</view>
        <text class="more">更多路线 ></text>
      </view>
      <scroll-view class="route-scroll" scroll-x enhanced show-scrollbar="{{false}}">
        <view class="route-list">
          <view class="route-card" wx:for="{{routes}}" wx:key="id">
            <view class="route-cover {{item.id}}">
              <text>{{item.tag}}</text>
            </view>
            <view class="route-body">
              <view class="route-title-row">
                <text class="route-title">{{item.audience}}</text>
                <text class="route-tag">{{item.tag}}</text>
              </view>
              <text class="route-focus">{{item.focus}}</text>
              <view class="route-bottom">
                <text class="duration">约{{item.duration}}</text>
                <button class="start-btn" bindtap="chooseRoute" data-interest="{{item.id}}">开始游览</button>
              </view>
            </view>
          </view>
        </view>
      </scroll-view>
    </view>

    <view class="section">
      <view class="section-title">景区百科</view>
      <view class="tile-grid">
        <view class="tile-card {{item.tone}}" wx:for="{{encyclopedia}}" wx:key="title">
          <text class="tile-icon">{{item.icon}}</text>
          <text class="tile-title">{{item.title}}</text>
          <text class="tile-subtitle">{{item.subtitle}}</text>
        </view>
      </view>
    </view>

    <view class="section service-section">
      <view class="service-panel">
        <view class="service-item" wx:for="{{services}}" wx:key="label">
          <view class="service-icon">{{item.icon}}</view>
          <text>{{item.label}}</text>
        </view>
      </view>
    </view>
  </scroll-view>

  <view class="player-bar">
    <view class="thumb">佛</view>
    <view class="player-main">
      <view class="player-line">
        <text class="player-title">正在讲解：{{currentSpotName}}</text>
        <text class="player-time">02:15 / 04:30</text>
      </view>
      <view class="progress-track">
        <view class="progress-fill" style="width: {{progress}}%;"></view>
      </view>
    </view>
    <button class="play-btn" bindtap="togglePlay">{{isPlaying ? '停' : '播'}}</button>
  </view>

  <view class="tabbar">
    <view class="tab-item {{item.active ? 'active' : ''}}" wx:for="{{navItems}}" wx:key="label">
      <text class="tab-icon">{{item.icon}}</text>
      <text>{{item.label}}</text>
    </view>
  </view>
</view>
