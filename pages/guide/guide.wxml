<view class="page-shell">
  <scroll-view class="content" scroll-y enhanced show-scrollbar="{{false}}" scroll-into-view="{{scrollTarget}}" scroll-with-animation>
    <view id="home-section" class="status-bar">
      <text class="time">09:41</text>
      <view class="status-right">
        <text class="location">{{scenic.name}}</text>
        <text class="signal">信</text>
        <text class="signal">网</text>
        <text class="battery"></text>
      </view>
    </view>

    <view id="guide-section" class="hero">
      <view class="ink-bg"></view>
      <view class="lotus-decoration">莲</view>

      <view class="avatar-wrap {{currentMood}}">
        <image class="avatar-image" src="/assets/guide/avatar.jpg" mode="aspectFill"></image>
        <view class="listening">正在聆听...</view>
      </view>

      <view class="dialogue-card">
        <view class="bubble-tip"></view>
        <text class="dialogue-text">{{dialogue}}</text>
        <view class="wave-row">
          <view class="wave wave-gold wave-1"></view>
          <view class="wave wave-red wave-2"></view>
          <view class="wave wave-gold wave-3"></view>
          <view class="wave wave-red wave-4"></view>
          <view class="wave wave-gold wave-5"></view>
        </view>
      </view>
    </view>

    <view class="control-row">
      <view class="side-action" bindtap="toggleQuestionBox" role="button" aria-label="文本输入">
        <view class="icon-keyboard">
          <view class="key-row">
            <view></view><view></view><view></view>
          </view>
          <view class="key-row">
            <view></view><view></view><view></view>
          </view>
        </view>
      </view>
      <view class="voice-action" bindtap="askQuestion" role="button" aria-label="语音提问">
        <view class="icon-mic"></view>
      </view>
      <view class="side-action" bindtap="useQuickQuestion" data-question="九龙灌浴适合孩子看吗？" role="button" aria-label="拍照识别">
        <view class="icon-camera"></view>
      </view>
    </view>

    <view class="question-box" wx:if="{{showQuestionBox}}">
      <input class="question-input" placeholder="问问小灵：灵山大佛有什么特色？" value="{{question}}" bindinput="onQuestionInput" confirm-type="send" bindconfirm="askQuestion" />
      <button class="send-btn" bindtap="askQuestion">发送</button>
    </view>

    <view id="route-section" class="section route-section">
      <view class="section-head">
        <view class="section-title">推荐路线</view>
        <text class="more">更多路线 ></text>
      </view>
      <scroll-view class="route-scroll" scroll-x enhanced show-scrollbar="{{false}}">
        <view class="route-list">
          <view class="route-card" wx:for="{{routes}}" wx:key="id">
            <image class="route-image" src="{{item.image}}" mode="aspectFill"></image>
            <view class="route-body">
              <view class="route-title-row">
                <text class="route-title">{{item.displayTitle}}</text>
                <text class="route-tag {{item.id}}">{{item.category}}</text>
              </view>
              <text class="route-path">{{item.path}}</text>
              <view class="tag-row">
                <text class="hash-tag">{{item.hashTag}}</text>
              </view>
              <view class="route-bottom">
                <text class="duration">约{{item.displayDuration}}</text>
                <button class="start-btn" bindtap="chooseRoute" data-interest="{{item.id}}">开始游览</button>
              </view>
            </view>
          </view>
        </view>
      </scroll-view>
    </view>

    <view class="section">
      <view class="section-title">景区百科</view>
      <view class="tile-grid">
        <view class="tile-card {{item.tone}}" wx:for="{{encyclopedia}}" wx:key="title">
          <text class="tile-icon">{{item.icon}}</text>
          <text class="tile-title">{{item.title}}</text>
          <text class="tile-subtitle">{{item.subtitle}}</text>
        </view>
      </view>
    </view>

    <view class="section service-section">
      <view class="service-panel">
        <view class="service-item" wx:for="{{services}}" wx:key="label">
          <view class="service-icon">{{item.icon}}</view>
          <text>{{item.label}}</text>
        </view>
      </view>
    </view>

    <view id="profile-section" class="section profile-section">
      <view class="section-title">我的导览</view>
      <view class="profile-card">
        <view class="profile-avatar">灵</view>
        <view class="profile-main">
          <text class="profile-title">游客体验档案</text>
          <text class="profile-desc">偏好：文化讲解 / 当前路线：{{currentRoute.displayTitle}}</text>
        </view>
      </view>
      <view class="profile-stats">
        <view>
          <text class="profile-num">3</text>
          <text class="profile-label">已推荐路线</text>
        </view>
        <view>
          <text class="profile-num">6</text>
          <text class="profile-label">百科条目</text>
        </view>
        <view>
          <text class="profile-num">98%</text>
          <text class="profile-label">匹配度</text>
        </view>
      </view>
    </view>
  </scroll-view>

  <view class="player-bar">
    <image class="thumb" src="/assets/guide/player-thumb.jpg" mode="aspectFill"></image>
    <view class="player-main">
      <view class="player-line">
        <text class="player-title">正在讲解：{{currentSpotName}} · 佛手广场</text>
        <text class="player-time">02:15 / 04:30</text>
      </view>
      <view class="progress-track">
        <view class="progress-fill" style="width: {{progress}}%;"></view>
      </view>
      <text class="player-desc">云端俯瞰太湖全景，感受灵山胜境的佛国气象</text>
    </view>
    <view class="play-btn" bindtap="togglePlay" role="button" aria-label="播放讲解">
      <view class="icon-audio {{playIconClass}}"></view>
    </view>
  </view>

  <view class="tabbar">
    <view class="tab-item {{item.activeClass}}" wx:for="{{navItems}}" wx:key="label" bindtap="handleNav" data-page="{{item.page}}" data-tab="{{item.tab}}" data-target="{{item.target}}">
      <text class="tab-icon">{{item.icon}}</text>
      <text>{{item.label}}</text>
    </view>
  </view>
</view>
