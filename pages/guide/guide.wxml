<view class="page-shell">
  <scroll-view class="content" scroll-y enhanced show-scrollbar="{{false}}">
    <view class="hero">
      <view class="ink-bg"></view>
      <view class="lotus-decoration">莲</view>

      <view class="avatar-wrap {{currentMood}}">
        <image class="avatar-image" src="/assets/guide/avatar.jpg" mode="aspectFill"></image>
        <view class="listening">{{isAsking ? '思考中...' : '在线导览'}}</view>
      </view>

      <view class="dialogue-card">
        <view class="bubble-tip"></view>
        <text class="dialogue-text">{{dialogue}}</text>
        <text class="ai-source">{{aiSourceText}}</text>
        <view class="wave-row">
          <view class="wave wave-gold wave-1"></view>
          <view class="wave wave-red wave-2"></view>
          <view class="wave wave-gold wave-3"></view>
          <view class="wave wave-red wave-4"></view>
          <view class="wave wave-gold wave-5"></view>
        </view>
      </view>
    </view>

    <view class="chat-panel">
      <view class="section-title">和灵灵对话</view>
      <view class="message-list">
        <view class="message {{item.role}}" wx:for="{{messages}}" wx:key="index">
          <text class="message-content">{{item.content}}</text>
          <text class="message-meta">{{item.meta}}</text>
        </view>
      </view>
      <view class="question-box">
        <input class="question-input" placeholder="直接问：灵山大佛最值得看什么？" value="{{question}}" bindinput="onQuestionInput" confirm-type="send" bindconfirm="askQuestion" />
        <button class="send-btn" loading="{{isAsking}}" bindtap="askQuestion">{{isAsking ? '生成中' : '发送'}}</button>
      </view>
    </view>

    <view class="quick-panel">
      <view class="section-title">快速提问</view>
      <view class="quick-grid">
        <button class="quick-btn" wx:for="{{quickQuestions}}" wx:key="item" bindtap="useQuickQuestion" data-question="{{item}}">{{item}}</button>
      </view>
    </view>

    <view class="section route-section">
      <view class="section-head">
        <view class="section-title">推荐路线</view>
        <text class="more">更多路线 ></text>
      </view>
      <scroll-view class="route-scroll" scroll-x enhanced show-scrollbar="{{false}}">
        <view class="route-list">
          <view class="route-card" wx:for="{{routes}}" wx:key="id">
            <image class="route-image" src="{{item.image}}" mode="aspectFill"></image>
            <view class="route-body">
              <view class="route-title-row">
                <text class="route-title">{{item.displayTitle}}</text>
                <text class="route-tag {{item.id}}">{{item.category}}</text>
              </view>
              <text class="route-path">{{item.path}}</text>
              <view class="tag-row">
                <text class="hash-tag">{{item.hashTag}}</text>
              </view>
              <view class="route-bottom">
                <text class="duration">约{{item.displayDuration}}</text>
                <button class="start-btn route-start-btn" bindtap="chooseRoute" data-interest="{{item.id}}">开始</button>
              </view>
            </view>
          </view>
        </view>
      </scroll-view>
    </view>

    <view class="section">
      <view class="section-title">景区百科</view>
      <view class="tile-grid">
        <view class="tile-card {{item.tone}}" wx:for="{{encyclopedia}}" wx:key="title">
          <text class="tile-icon">{{item.icon}}</text>
          <text class="tile-title">{{item.title}}</text>
          <text class="tile-subtitle">{{item.subtitle}}</text>
        </view>
      </view>
    </view>

    <view class="section service-section">
      <view class="service-panel">
        <view class="service-item" wx:for="{{services}}" wx:key="label">
          <view class="service-icon">{{item.icon}}</view>
          <text>{{item.label}}</text>
        </view>
      </view>
    </view>
  </scroll-view>

  <view class="player-bar">
    <image class="thumb" src="/assets/guide/player-thumb.jpg" mode="aspectFill"></image>
    <view class="player-main">
      <view class="player-line">
        <text class="player-title">正在讲解：{{currentSpotName}}</text>
        <text class="player-time">02:15 / 04:30</text>
      </view>
      <view class="progress-track">
        <view class="progress-fill" style="width: {{progress}}%;"></view>
      </view>
      <text class="player-desc">数字人灵灵正在根据您的问题生成讲解内容</text>
    </view>
    <view class="play-btn" bindtap="togglePlay" role="button" aria-label="播放讲解">
      <view class="icon-audio {{playIconClass}}"></view>
    </view>
  </view>
</view>
