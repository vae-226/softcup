.page-shell {
  min-height: 100vh;
  background: #f2e6ce;
  color: #2b2b2b;
  font-family: serif;
  position: relative;
  overflow: hidden;
}

.content {
  height: 100vh;
  padding-bottom: 300rpx;
  box-sizing: border-box;
}

.hero {
  height: 800rpx;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.ink-bg {
  position: absolute;
  inset: 0 0 160rpx;
  background: radial-gradient(circle at 50% 50%, #e8d5b5 0%, #f2e6ce 100%);
}

.lotus-decoration {
  position: absolute;
  right: 34rpx;
  bottom: 30rpx;
  z-index: 1;
  color: #c5a55a;
  font-size: 112rpx;
  opacity: 0.08;
  pointer-events: none;
}

.avatar-wrap {
  width: 384rpx;
  height: 384rpx;
  border-radius: 50%;
  border: 8rpx solid rgba(197, 165, 90, 0.3);
  position: relative;
  z-index: 2;
  overflow: visible;
  box-shadow: 0 0 40rpx rgba(197, 165, 90, 0.3), 0 0 80rpx rgba(178, 34, 34, 0.15);
  animation: breathe 3s ease-in-out infinite;
}

.avatar-image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  display: block;
}

.listening {
  position: absolute;
  left: 50%;
  bottom: -18rpx;
  transform: translateX(-50%);
  background: #c5a55a;
  color: white;
  border-radius: 999rpx;
  padding: 8rpx 24rpx;
  font-size: 20rpx;
  box-shadow: 0 12rpx 28rpx rgba(77, 52, 14, 0.18);
  z-index: 3;
}

.dialogue-card {
  width: calc(100% - 96rpx);
  margin-top: 66rpx;
  padding: 30rpx 32rpx 24rpx;
  border-radius: 32rpx;
  border: 1rpx solid rgba(197, 165, 90, 0.2);
  background: rgba(255, 255, 255, 0.7);
  box-shadow: 0 12rpx 36rpx rgba(57, 38, 18, 0.08);
  position: relative;
  z-index: 2;
  box-sizing: border-box;
}

.bubble-tip {
  position: absolute;
  top: -12rpx;
  left: 50%;
  width: 28rpx;
  height: 28rpx;
  transform: translateX(-50%) rotate(45deg);
  background: rgba(255, 255, 255, 0.7);
  border-left: 1rpx solid rgba(197, 165, 90, 0.2);
  border-top: 1rpx solid rgba(197, 165, 90, 0.2);
}

.dialogue-text {
  display: block;
  text-align: center;
  font-size: 27rpx;
  line-height: 1.72;
}

.wave-row {
  height: 32rpx;
  margin-top: 16rpx;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  gap: 4rpx;
}

.wave {
  width: 4rpx;
  height: 8rpx;
  border-radius: 99rpx;
  animation: wave 1s ease-in-out infinite;
}

.wave-gold {
  background: #c5a55a;
}

.wave-red {
  background: #b22222;
}

.wave-2 { animation-delay: 0.15s; }
.wave-3 { animation-delay: 0.3s; }
.wave-4 { animation-delay: 0.45s; }
.wave-5 { animation-delay: 0.6s; }

.control-row {
  margin-top: -38rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 64rpx;
  position: relative;
  z-index: 5;
}

.send-btn,
.start-btn {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  line-height: 1;
}

.send-btn::after,
.start-btn::after {
  border: 0;
}

.side-action,
.voice-action {
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: visible;
}

.side-action {
  width: 104rpx;
  height: 104rpx;
  min-width: 104rpx;
  max-width: 104rpx;
  flex: 0 0 104rpx;
  background: rgba(255, 255, 255, 0.82);
  border: 1rpx solid rgba(43, 43, 43, 0.08);
  color: #68615b;
  box-shadow: 0 12rpx 24rpx rgba(33, 25, 17, 0.12);
}

.voice-action {
  width: 150rpx;
  height: 150rpx;
  min-width: 150rpx;
  max-width: 150rpx;
  flex: 0 0 150rpx;
  background: #c5a55a;
  color: white;
  box-shadow: 0 22rpx 42rpx rgba(125, 91, 22, 0.32);
  position: relative;
}

.voice-action::before {
  content: "";
  position: absolute;
  inset: 0;
  border-radius: 50%;
  background: #c5a55a;
  animation: pulse-ring 2s cubic-bezier(0.24, 0, 0.38, 1) infinite;
  z-index: -1;
}

.icon-keyboard {
  width: 48rpx;
  height: 36rpx;
  border: 4rpx solid #68615b;
  border-radius: 10rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 6rpx;
  padding: 5rpx 6rpx;
  box-sizing: border-box;
}

.key-row {
  display: flex;
  justify-content: space-between;
}

.key-row view {
  width: 7rpx;
  height: 5rpx;
  border-radius: 3rpx;
  background: #68615b;
}

.icon-mic {
  width: 42rpx;
  height: 68rpx;
  position: relative;
}

.icon-mic::before {
  content: "";
  position: absolute;
  left: 50%;
  top: 0;
  width: 34rpx;
  height: 48rpx;
  transform: translateX(-50%);
  border-radius: 18rpx;
  background: #fff;
}

.icon-mic::after {
  content: "";
  position: absolute;
  left: 50%;
  bottom: 0;
  width: 42rpx;
  height: 24rpx;
  transform: translateX(-50%);
  border-bottom: 6rpx solid #fff;
  border-left: 6rpx solid #fff;
  border-right: 6rpx solid #fff;
  border-radius: 0 0 24rpx 24rpx;
  box-sizing: border-box;
}

.icon-camera {
  width: 52rpx;
  height: 38rpx;
  border: 4rpx solid #68615b;
  border-radius: 10rpx;
  position: relative;
  box-sizing: border-box;
}

.icon-camera::before {
  content: "";
  position: absolute;
  left: 8rpx;
  top: -12rpx;
  width: 20rpx;
  height: 10rpx;
  border-radius: 6rpx 6rpx 0 0;
  background: #68615b;
}

.icon-camera::after {
  content: "";
  position: absolute;
  left: 50%;
  top: 50%;
  width: 16rpx;
  height: 16rpx;
  transform: translate(-50%, -50%);
  border: 4rpx solid #68615b;
  border-radius: 50%;
  box-sizing: border-box;
}

.question-box {
  margin: 36rpx 48rpx 0;
  display: flex;
  gap: 16rpx;
}

.question-input {
  flex: 1;
  min-width: 0;
  height: 76rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.72);
  padding: 0 26rpx;
  font-size: 24rpx;
  box-shadow: inset 0 0 0 1rpx rgba(43, 43, 43, 0.08);
  box-sizing: border-box;
}

.send-btn {
  width: 112rpx;
  height: 76rpx;
  border-radius: 999rpx;
  background: #2b2b2b;
  color: white;
  font-size: 24rpx;
  line-height: 76rpx;
}

.section {
  margin-top: 76rpx;
  padding: 0 48rpx;
}

.route-section {
  margin-top: 82rpx;
}

.section-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-bottom: 28rpx;
}

.section-title {
  border-left: 8rpx solid #c5a55a;
  padding-left: 20rpx;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.25;
}

.more {
  font-size: 22rpx;
  color: #777;
}

.route-scroll {
  width: 100%;
  white-space: nowrap;
}

.route-list {
  display: flex;
  gap: 28rpx;
}

.route-card {
  width: 520rpx;
  display: flex;
  flex-direction: column;
  background: white;
  border-radius: 28rpx;
  overflow: hidden;
  border: 1rpx solid rgba(43, 43, 43, 0.06);
  box-shadow: 0 10rpx 28rpx rgba(42, 33, 22, 0.08);
}

.route-image {
  width: 100%;
  height: 256rpx;
  display: block;
}

.route-body {
  padding: 26rpx;
}

.route-title-row,
.route-bottom,
.player-line {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.route-title {
  min-width: 0;
  font-size: 29rpx;
  font-weight: 700;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.route-tag {
  flex: none;
  border-radius: 8rpx;
  padding: 5rpx 14rpx;
  background: #f2e6ce;
  color: #c5a55a;
  font-size: 19rpx;
}

.route-tag.family {
  background: #eef4ff;
  color: #3764aa;
}

.route-tag.nature {
  background: #edf8ef;
  color: #2f7c43;
}

.route-path {
  display: block;
  margin-top: 10rpx;
  color: #666;
  font-size: 22rpx;
  line-height: 1.55;
  white-space: normal;
}

.tag-row {
  margin-top: 14rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.hash-tag {
  border-radius: 8rpx;
  padding: 5rpx 10rpx;
  background: #f2f2f2;
  color: #666;
  font-size: 18rpx;
}

.route-bottom {
  margin-top: 20rpx;
}

.duration {
  color: #888;
  font-size: 22rpx;
}

.start-btn {
  width: 150rpx;
  height: 56rpx;
  border-radius: 999rpx;
  background: #2b2b2b;
  color: white;
  font-size: 22rpx;
  line-height: 56rpx;
}

.tile-grid {
  margin-top: 28rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
}

.tile-card {
  min-height: 174rpx;
  padding: 28rpx 18rpx;
  border-radius: 24rpx;
  border: 1rpx solid rgba(43, 43, 43, 0.1);
  background: rgba(255, 255, 255, 0.42);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  box-sizing: border-box;
}

.tile-icon {
  font-size: 50rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.tile-title {
  font-size: 26rpx;
  font-weight: 700;
}

.tile-subtitle {
  margin-top: 8rpx;
  font-size: 20rpx;
  color: #666;
  line-height: 1.45;
}

.tile-card.gold .tile-icon { color: #c5a55a; }
.tile-card.red .tile-icon { color: #b22222; }
.tile-card.ink .tile-icon { color: #1a2c42; }
.tile-card.green .tile-icon { color: #2f6d48; }
.tile-card.orange .tile-icon { color: #c7662a; }

.service-section {
  margin-bottom: 72rpx;
}

.service-panel {
  background: #2b2b2b;
  border-radius: 28rpx;
  padding: 26rpx 18rpx;
  display: flex;
  justify-content: space-around;
  box-shadow: 0 14rpx 30rpx rgba(33, 25, 17, 0.18);
}

.service-item {
  color: #ddd;
  font-size: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.service-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
}

.profile-section {
  margin-bottom: 250rpx;
}

.profile-card {
  margin-top: 28rpx;
  border-radius: 28rpx;
  padding: 28rpx;
  background: rgba(255, 255, 255, 0.68);
  border: 1rpx solid rgba(197, 165, 90, 0.18);
  display: flex;
  align-items: center;
  gap: 22rpx;
  box-shadow: 0 12rpx 30rpx rgba(42, 33, 22, 0.08);
}

.profile-avatar {
  width: 84rpx;
  height: 84rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #b22222, #c5a55a);
  color: #fff;
  font-size: 42rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: none;
}

.profile-main {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.profile-title {
  font-size: 29rpx;
  font-weight: 700;
}

.profile-desc {
  color: #666;
  font-size: 22rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.profile-stats {
  margin-top: 20rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.profile-stats view {
  border-radius: 22rpx;
  padding: 22rpx 12rpx;
  background: rgba(255, 255, 255, 0.55);
  border: 1rpx solid rgba(43, 43, 43, 0.08);
  text-align: center;
}

.profile-num {
  display: block;
  color: #c5a55a;
  font-size: 32rpx;
  font-weight: 700;
}

.profile-label {
  display: block;
  margin-top: 6rpx;
  color: #777;
  font-size: 20rpx;
}

.player-bar {
  position: fixed;
  left: 32rpx;
  right: 32rpx;
  bottom: 150rpx;
  z-index: 20;
  border-radius: 28rpx;
  border: 1rpx solid rgba(197, 165, 90, 0.3);
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 18rpx 40rpx rgba(38, 26, 16, 0.18);
  padding: 20rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.thumb {
  width: 80rpx;
  height: 80rpx;
  border-radius: 18rpx;
  flex: none;
}

.player-main {
  flex: 1;
  min-width: 0;
}

.player-title {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 22rpx;
  font-weight: 700;
}

.player-time {
  flex: none;
  color: #888;
  font-size: 18rpx;
}

.progress-track {
  margin-top: 10rpx;
  height: 8rpx;
  background: #dedede;
  border-radius: 999rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: #c5a55a;
  border-radius: inherit;
}

.player-desc {
  display: block;
  margin-top: 8rpx;
  color: #888;
  font-size: 18rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.play-btn {
  width: 68rpx;
  height: 68rpx;
  min-width: 68rpx;
  max-width: 68rpx;
  border-radius: 50%;
  background: #c5a55a;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: none;
}

.icon-audio {
  position: relative;
  display: block;
}

.icon-audio.play {
  width: 0;
  height: 0;
  margin-left: 5rpx;
  border-top: 15rpx solid transparent;
  border-bottom: 15rpx solid transparent;
  border-left: 22rpx solid #fff;
}

.icon-audio.pause {
  width: 24rpx;
  height: 30rpx;
}

.icon-audio.pause::before,
.icon-audio.pause::after {
  content: "";
  position: absolute;
  top: 0;
  width: 8rpx;
  height: 30rpx;
  border-radius: 3rpx;
  background: #fff;
}

.icon-audio.pause::before {
  left: 0;
}

.icon-audio.pause::after {
  right: 0;
}

@keyframes breathe {
  0%, 100% {
    transform: scale(1);
    opacity: 0.96;
    box-shadow: 0 0 40rpx rgba(197, 165, 90, 0.3), 0 0 80rpx rgba(178, 34, 34, 0.15);
  }
  50% {
    transform: scale(1.05);
    opacity: 1;
    box-shadow: 0 0 80rpx rgba(197, 165, 90, 0.5), 0 0 120rpx rgba(178, 34, 34, 0.3);
  }
}

@keyframes wave {
  0%, 100% { height: 8rpx; }
  50% { height: 32rpx; }
}

@keyframes pulse-ring {
  0% {
    transform: scale(0.8);
    opacity: 0.5;
  }
  100% {
    transform: scale(1.5);
    opacity: 0;
  }
}
